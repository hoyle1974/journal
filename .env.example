# Jot Journal - Environment variables
# Copy to .env and fill in values. Never commit .env.

# === CLI (cmd/jot) - where to send API requests ===
JOT_API_URL=                    # e.g. https://us-central1-PROJECT.cloudfunctions.net/jot-api-go
JOT_API_KEY=                    # From Secret Manager or .env
# (Deploy sets JOT_API_URL for Cloud Run so the API can enqueue tasks to itself. Local server without it runs process-entry inline.)
MACHINE_NAME=                   # Optional; defaults to hostname

# === Cloud / Local dev ===
GOOGLE_CLOUD_PROJECT=
DOCUMENT_ID=                    # Google Doc ID for sync
SERVICE_ACCOUNT_FILE=           # Path to credentials.json (local dev)
SYNC_GDOC_URL=                  # Set by deploy; used for Drive webhook

# === Secrets (loaded from env locally, Secret Manager in cloud) ===
GEMINI_API_KEY=                 # Required for queries/summaries

# === Twilio (SMS) - also in Secret Manager ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ALLOWED_PHONE_NUMBER=

# === Drive watch (setup_drive_watch.py) ===
GDOC_WEBHOOK_URL=               # Optional; defaults to cloud function URL
